@model IEnumerable<Almacen>

@{
    ViewData["Title"] = "Lista de Almacen";
}

<div class="container-xl">
    <h1 class="text-center mt-4">Lista de Almacenes</h1>
    <div class="text-md-end mb-3">
        <a asp-area="Admin" asp-controller="Almacen" asp-action="Crear" class="btn btn-success bg-gradient"> <i class="bi bi-plus-circle"></i> Nuevo Almacen</a>
    </div>
    @if (Model.Count() > 0)
    {
        <div class="table-responsive shadow p-3 rounded bg-white">
            <table id="tblDatos" class="table table-striped table-hover w-100">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Descripcion</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-danger" role="alert">
            No hay registro para mostrar
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/almacen.js"></script>
}

